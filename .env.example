# Copy this file to .env and fill in values for your environment.
# The test suite uses these defaults when variables are not set.

# Base URL of the application under test (default: https://test.com)
BASE_URL=https://test.com

# Authenticated test user credentials
USER_EMAIL=test123@gmail.com
USER_ACCOUNT_ID=98765

# Browser locale and timezone (default: en-IN / Asia/Kolkata)
LOCALE=en-IN
TIMEZONE=Asia/Kolkata
